NODE_ENV=development
PORT=3006
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stayflexi
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-replace-in-production
SERVICE_KEY=your-internal-service-key
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=false
KAFKA_GROUP_ID=payment-service
IDEMPOTENCY_TTL_SECONDS=86400
PAYMENT_CACHE_TTL_SECONDS=300
INVOICE_CACHE_TTL_SECONDS=600
MAX_REFUND_DAYS=30
DEFAULT_TAX_RATE=0.10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=debug
JAEGER_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces
WEBHOOK_SECRET=change-this-to-a-random-secret-in-production
