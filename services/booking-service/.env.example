NODE_ENV=development
PORT=3005
DATABASE_URL=postgresql://stayflexi:stayflexi_dev@localhost:5432/stayflexi
REDIS_URL=redis://:redis_dev@localhost:6379
SERVICE_KEY=your-internal-service-key-minimum-32-chars
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=false
KAFKA_CLIENT_ID=booking-service
KAFKA_GROUP_ID=booking-service
BOOKING_LOCK_TTL_MS=30000
