// ─── Auth Domain ───────────────────────────────────────────────────────────────
// Owns: User identity, credential storage, session tokens, password resets.
// Cross-domain relations: Organization (owned by organization.prisma),
// AuditLog back-relation (owned by common.prisma).

model User {
  id              String       @id @default(uuid())
  email           String       @unique @db.VarChar(255)
  passwordHash    String       @db.VarChar(255)
  firstName       String       @db.VarChar(100)
  lastName        String       @db.VarChar(100)
  phone           String?      @db.VarChar(20)
  primaryRole     UserRoleType @default(FRONT_DESK)
  status          UserStatus   @default(PENDING_VERIFICATION)
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  // Multi-tenant anchor: null only for SUPER_ADMIN
  organizationId String?
  organization   Organization? @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: SetNull)

  // Auth relations
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  // RBAC relations
  userRoles UserRole[]

  // Audit back-relation
  auditLogs AuditLog[] @relation("UserAuditLogs")

  // Security module back-relation
  userSessions UserSession[] @relation("UserSessions")

  // Owned organizations (user can be owner of exactly one org)
  ownedOrganization Organization? @relation("OrganizationOwner")

  @@index([email])
  @@index([organizationId])
  @@index([primaryRole])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ─── RefreshToken ──────────────────────────────────────────────────────────────
// Stores hashed refresh tokens only — plaintext never persisted.
// revokedAt enables token family revocation without hard delete.

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(255)
  ipAddress String?   @db.VarChar(45)
  userAgent String?   @db.VarChar(500)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── PasswordResetToken ────────────────────────────────────────────────────────
// Short-lived one-time tokens for password recovery.
// usedAt marks consumption; expired+unused tokens cleaned by scheduled job.

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
