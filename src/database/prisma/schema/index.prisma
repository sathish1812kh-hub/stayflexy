// ─── Generator & Datasource ────────────────────────────────────────────────────
// This is the sole entry point for Prisma tooling.
// Multi-file schema: all *.prisma files in this directory are merged at generation time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
