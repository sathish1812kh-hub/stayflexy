IDEMPOTENCY_TTL_SECONDS=86400
BOOKING_CACHE_TTL_SECONDS=300
MAX_ROOMS_PER_BOOKING=10
MAX_ADVANCE_BOOKING_DAYS=365
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
LOG_LEVEL=debug
