  PAYMENT
  INVENTORY
  HOUSEKEEPING_TASK
  RATE_PLAN
  NOTIFICATION
}

// ─── AuditLog ──────────────────────────────────────────────────────────────────
// Immutable append-only record of all state-changing operations.
// onDelete: Restrict on userId and organizationId intentionally prevents
// deletion of users/orgs that have audit history — require archival first.

model AuditLog {
  id             String        @id @default(uuid())
  action         AuditAction
  resource       AuditResource
  resourceId     String        @db.VarChar(255)
  userId         String
  user           User          @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Restrict)
  organizationId String
  organization   Organization  @relation("OrganizationAuditLogs", fields: [organizationId], references: [id], onDelete: Restrict)
  ipAddress      String?       @db.VarChar(45)
  userAgent      String?       @db.VarChar(500)
  before         Json?
  after          Json?
  duration       Int? // milliseconds
  success        Boolean       @default(true)
  errorMessage   String?       @db.VarChar(1000)
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
