# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=stayflexi
APP_VERSION=1.1.0
APP_PORT=3000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev@localhost:6379
REDIS_PASSWORD=redis_dev

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Scaling ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
INSTANCE_COUNT=1
INSTANCE_ID=

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/stayflexi_dev?schema=public
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=30000

# ─── Authentication (Phase 2) ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_64_chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ─── API ────────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000
API_VERSION=v1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Gemini AI Assistant ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Neo4j & Graphiti Memory (Phase 3 & 4) ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=stayflexi-dev-pass
GRAPHITI_ENV=development
